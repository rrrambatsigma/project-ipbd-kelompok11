# ═══════════════════════════════════════════════
# 📰 ANALISIS MARKET FLOW NILAI TUKAR EURO
# Kelompok 11 — IPBD
# ═══════════════════════════════════════════════
# Salin file ini ke .env lalu isi nilai yang sesuai
# cp .env.example .env
# ═══════════════════════════════════════════════

# ─────────────────────────────────────────
# MINIO — Object Storage S3-compatible
# ─────────────────────────────────────────
MINIO_ENDPOINT=minio:9000            # host.docker.internal:9000 (jika dari luar docker)
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET_RAW=news-raw
MINIO_BUCKET_PROCESSED=news-processed

# ─────────────────────────────────────────
# PORTS — Mapping host:container
# ─────────────────────────────────────────
SERVING_PORT=8000                    # Backend API FastAPI
MINIO_API_PORT=9000                  # MinIO S3 API
MINIO_CONSOLE_PORT=9001              # MinIO Web UI
PREFECT_PORT=4200                    # Prefect Server UI
SELENIUM_PORT=4444                   # Selenium Chrome
POSTGRES_PORT=5432                   # PostgreSQL (internal)
PUSHGATEWAY_PORT=9091                # Prometheus Pushgateway
PROMETHEUS_PORT=9090                 # Prometheus UI
GRAFANA_PORT=3000                    # Grafana Dashboard

# ─────────────────────────────────────────
# NEWSAPI.ORG — https://newsapi.org/
# Free tier: 100 req/hari
# ─────────────────────────────────────────
NEWSAPI_KEY=your-newsapi-key

# ─────────────────────────────────────────
# GUARDIAN API — https://open-platform.theguardian.com/
# ─────────────────────────────────────────
GUARDIAN_API_KEY=your-guardian-api-key

# ─────────────────────────────────────────
# PREFECT — Workflow Orchestration
# ─────────────────────────────────────────
PREFECT_API_URL=http://localhost:4200/api

# ─────────────────────────────────────────
# SELENIUM — Headless Browser
# ─────────────────────────────────────────
SELENIUM_HUB_URL=http://localhost:4444/wd/hub

# ─────────────────────────────────────────
# SCRAPER SETTINGS
# ─────────────────────────────────────────
SCRAPER_REQUEST_TIMEOUT=30           # detik
SCRAPER_MAX_RETRIES=3
SCRAPER_DELAY_SECONDS=2

# ─────────────────────────────────────────
# TELEGRAM — Bot Notifikasi
# ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=8218332717:AAHS1ks7C8qs3y6Ubo81yDkINp_FGbf5dCI  # Bot khusus preprocessing
TELEGRAM_BOT_TOKEN_MODELLING=8883638359:AAFlmg19cd5oOdhFPDQbXSNZrW8r7nHgcPk  # Bot khusus modelling
TELEGRAM_CHAT_ID=5974165452
TELEGRAM_CHAT_ID_MODELLING=-1004360195236  # Chat ID grup IPBD 11 GACOR

# ─────────────────────────────────────────
# FAILURE NOTIFIER — Bot notifikasi job gagal
# Bot khusus untuk pipeline gabungan analisis korelasi
# ─────────────────────────────────────────
FAILURE_BOT_TOKEN=8621358465:AAE5Pbny2yUzchVo6U9fjJW2eMfV1xmYYSA
FAILURE_CHAT_ID=-1004360195236

# ─────────────────────────────────────────
# BACKFILL — Historical Data Range
# ─────────────────────────────────────────
BACKFILL_START=2021-01-01
BACKFILL_END=2025-12-31

# ─────────────────────────────────────────
# SPARK — PySpark Configuration
# ─────────────────────────────────────────
SPARK_DRIVER_MEMORY=1g
SPARK_EXECUTOR_MEMORY=1g

# ─────────────────────────────────────────
# FASTTEXT — Language Detection Model
# ─────────────────────────────────────────
FASTTEXT_LID_PATH=/app/jobs/models/lid.176.ftz

# ─────────────────────────────────────────
# PROMETHEUS — Metrics
# ─────────────────────────────────────────
PUSHGATEWAY_URL=http://pushgateway:9091

# ─────────────────────────────────────────
# TIMEZONE
# ─────────────────────────────────────────
TZ=Asia/Jakarta

# ─────────────────────────────────────────
# PYTHON
# ─────────────────────────────────────────
PYTHONPATH=/app/flows
PYTHONUNBUFFERED=1
